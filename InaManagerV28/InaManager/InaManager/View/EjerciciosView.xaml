<UserControl x:Class="InaManager.View.EjerciciosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#40FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#30000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Visibility="{Binding IsListVisible}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="GESTOR DE EJERCICIOS" 
                           FontSize="24" Foreground="White" FontWeight="Bold" FontFamily="Montserrat" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" ShadowDepth="2" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding AddNewCommand}"
                            Content="+ NUEVO EJERCICIO" 
                            Background="#FFD700" Foreground="#333333" FontWeight="Bold" FontSize="14"
                            Height="35" Padding="15,0" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="17"/>
                            </Style>
                        </Button.Resources>
                        <Button.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.3" ShadowDepth="2"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" CornerRadius="15" Background="#15000000" BorderBrush="#30FFFFFF" BorderThickness="1">
                <DataGrid ItemsSource="{Binding ListaEjercicios}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#20FFFFFF"
                          VerticalGridLinesBrush="Transparent" RowBackground="Transparent" RowHeight="60">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="NOMBRE" Binding="{Binding nombre}" Width="250"/>

                        <DataGridTextColumn Header="CATEGORÍA" Binding="{Binding categoria}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FFD700"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="DESCRIPCIÓN" Binding="{Binding descripcion}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="Foreground" Value="#CCCCCC"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="ACCIÓN" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="EDITAR" 
                                                Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}"
                                                Background="#40FFFFFF" Foreground="White" Cursor="Hand" FontWeight="Bold" BorderThickness="0" Padding="8,4" FontSize="11" Margin="0,0,8,0">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="5"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>

                                        <Button Content="ELIMINAR" 
                                                Command="{Binding DataContext.DeleteFromGridCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}"
                                                Background="#C62828" Foreground="White" Cursor="Hand" FontWeight="Bold" BorderThickness="0" Padding="8,4" FontSize="11">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="5"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid Visibility="{Binding IsDetailVisible}" Background="#D0000000">
            <Border Background="#10000000" />

            <Button HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20"
                    Command="{Binding BackToListCommand}"
                    Content="🡠 VOLVER / CANCELAR" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand"
                    Panel.ZIndex="10"/>

            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="600">
                <Border Background="#20FFFFFF" CornerRadius="15" Padding="40" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="{Binding TituloDetalle}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,30" HorizontalAlignment="Center" FontFamily="Montserrat"/>

                        <TextBlock Text="Nombre del Ejercicio" Foreground="White" Opacity="0.7" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedEjercicio.nombre, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" FontSize="14" Height="35" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Categoría" Foreground="White" Opacity="0.7" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedEjercicio.categoria, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" FontSize="14" Height="35" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Descripción" Foreground="White" Opacity="0.7" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedEjercicio.descripcion, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,30" FontSize="14" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding SaveChangesCommand}" 
                                    Content="GUARDAR DATOS" 
                                    Background="#2E7D32" Foreground="White" FontWeight="Bold" Height="45" Cursor="Hand" BorderThickness="0" FontSize="14">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                                <Button.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.3" ShadowDepth="2"/>
                                </Button.Effect>
                            </Button>

                            <Button Grid.Column="2"
                                    Command="{Binding DeleteCommand}"
                                    Content="BORRAR / DESCARTAR" 
                                    Background="#C62828" Foreground="White" FontWeight="Bold" Height="45" Cursor="Hand" BorderThickness="0" FontSize="14">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                                <Button.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.3" ShadowDepth="2"/>
                                </Button.Effect>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Visibility="{Binding IsAlertVisible, Converter={StaticResource BoolToVis}}" Panel.ZIndex="999">
            <Border Background="#AA000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAlertCommand}"/>
                </Border.InputBindings>
            </Border>

            <Border Width="400" MinHeight="180" Background="#1E1E1E" 
                    BorderBrush="{Binding AlertColor}" BorderThickness="2" CornerRadius="12"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.8"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="⚠" FontSize="24" Foreground="{Binding AlertColor}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AlertTitle}" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding AlertMessage}" Foreground="#DDDDDD" FontSize="14" 
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25" LineHeight="20"/>
                    <Button Command="{Binding CloseAlertCommand}"
                            Content="ENTENDIDO" Width="120" Height="35"
                            Background="{Binding AlertColor}" Foreground="White" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="17"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>