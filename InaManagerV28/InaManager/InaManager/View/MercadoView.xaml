<UserControl x:Class="InaManager.View.MercadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InaManager.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1100"
             FontFamily="Montserrat">

    <UserControl.DataContext>
        <vm:MercadoViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Estilo TextBox tipo glassmorphism -->
        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#25FFFFFF"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#50FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,6"/>
            <Setter Property="FontFamily"   Value="Montserrat"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="CaretBrush"   Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botón de paginación -->
        <Style x:Key="PaginaBtn" TargetType="Button">
            <Setter Property="Background"        Value="#30FFFFFF"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="BorderBrush"       Value="#50FFFFFF"/>
            <Setter Property="Padding"           Value="18,8"/>
            <Setter Property="FontFamily"        Value="Montserrat"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#70FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botón de limpiar filtros -->
        <Style x:Key="LimpiarBtn" TargetType="Button" BasedOn="{StaticResource PaginaBtn}">
            <Setter Property="Background"  Value="#30E05050"/>
            <Setter Property="BorderBrush" Value="#60E05050"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="FontSize"    Value="11"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- VISTA DE LISTA -->
        <Grid Visibility="{Binding IsListVisible}">
            <Grid.RowDefinitions>
                <!-- Cabecera / título -->
                <RowDefinition Height="Auto"/>
                <!-- Barra de filtros -->
                <RowDefinition Height="Auto"/>
                <!-- Grid de tarjetas -->
                <RowDefinition Height="*"/>
                <!-- Paginación -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════ CABECERA ══════════════════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,18">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚽" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="MERCADO DE FICHAJES"
                               FontSize="22" FontWeight="Bold" Foreground="White"
                               FontFamily="Montserrat"/>
                    <TextBlock Text="{Binding TextoResultados}"
                               FontSize="12" Foreground="#AAAAAA" FontFamily="Montserrat"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="➕  Crear Anuncio"
                        Style="{StaticResource PaginaBtn}"
                        Padding="14,7" FontSize="12"
                        Command="{Binding CrearAnuncioCommand}"
                        Margin="0,0,10,0"/>
                <Button Content="↺  Actualizar"
                        Style="{StaticResource PaginaBtn}"
                        Padding="14,7" FontSize="12"
                        Click="BtnActualizar_Click"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════ FILTROS ══════════════════════ -->
        <Border Grid.Row="1" Background="#18FFFFFF" CornerRadius="12"
                BorderBrush="#30FFFFFF" BorderThickness="1"
                Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Búsqueda por nombre -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🔍  Buscar jugador" Foreground="#AAAAAA"
                               FontSize="10" FontFamily="Montserrat" Margin="2,0,0,4"/>
                    <TextBox Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource GlassTextBox}"
                             x:Name="TxtBusqueda"/>
                </StackPanel>

                <!-- Posición (grupo) -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="📍  Posición" Foreground="#AAAAAA"
                               FontSize="10" FontFamily="Montserrat" Margin="2,0,0,4"/>
                    <ComboBox ItemsSource="{Binding GruposPosicion}"
                              SelectedItem="{Binding GrupoPosicionSeleccionado}"
                              Style="{StaticResource EstiloComboBoxGlass}"
                              Height="32"/>
                </StackPanel>

                <!-- Elemento -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="✨  Elemento" Foreground="#AAAAAA"
                               FontSize="10" FontFamily="Montserrat" Margin="2,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Elementos}"
                              SelectedItem="{Binding ElementoSeleccionado}"
                              Style="{StaticResource EstiloComboBoxGlass}"
                              Height="32"/>
                </StackPanel>

                <!-- Precio máximo -->
                <StackPanel Grid.Column="6">
                    <TextBlock Text="💰  Precio máx. (€)" Foreground="#AAAAAA"
                               FontSize="10" FontFamily="Montserrat" Margin="2,0,0,4"/>
                    <TextBox Text="{Binding PrecioMaxTexto, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource GlassTextBox}"/>
                </StackPanel>

                <!-- Ordenar -->
                <StackPanel Grid.Column="8">
                    <TextBlock Text="↕  Ordenar por" Foreground="#AAAAAA"
                               FontSize="10" FontFamily="Montserrat" Margin="2,0,0,4"/>
                    <ComboBox ItemsSource="{Binding OpcionesOrden}"
                              SelectedItem="{Binding OrdenSeleccionado}"
                              Style="{StaticResource EstiloComboBoxGlass}"
                              Height="32"/>
                </StackPanel>

                <!-- Botón limpiar -->
                <StackPanel Grid.Column="10" VerticalAlignment="Bottom">
                    <Button Content="✕  Limpiar" Style="{StaticResource LimpiarBtn}"
                            Command="{Binding LimpiarFiltrosCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════ TARJETAS ══════════════════════ -->
        <Grid Grid.Row="2">
            <!-- Overlay de carga -->
            <Border Background="#80000000" CornerRadius="10"
                    Visibility="{Binding Cargando, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="10">
                <TextBlock Text="Cargando mercado..." Foreground="White"
                           FontSize="16" FontFamily="Montserrat"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Sin resultados -->
            <StackPanel Visibility="{Binding SinResultados, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="😕" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="No hay jugadores en mercado con esos filtros"
                           Foreground="#AAAAAA" FontSize="15" FontFamily="Montserrat"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Grid de tarjetas: 5 columnas uniformes -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding AnunciosPagina}" Margin="10,5">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- ═══ TARJETA INDIVIDUAL ═══ -->
                            <Border Margin="8,10" CornerRadius="16"
                                    BorderBrush="{Binding ColorBorde}"
                                    BorderThickness="1.5"
                                    Height="310"
                                    Width="180"
                                    Background="#1A1A2E"
                                    ClipToBounds="True"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#252545"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <!-- Imagen y fondo color -->
                                        <RowDefinition Height="150"/>
                                        <!-- Nombre -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Estadísticas -->
                                        <RowDefinition Height="*"/>
                                        <!-- Equipo y pie -->
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- ─── PARTE SUPERIOR: Imagen + Elemento ─── -->
                                    <Border Grid.Row="0" Background="{Binding ColorElemento}" CornerRadius="15,15,0,0">
                                        <Grid>
                                            <!-- Degradado decorativo -->
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#40000000" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                                        <GradientStop Color="#601A1A2E" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>



                                            <!-- Emoji del elemento -->
                                            <TextBlock Text="{Binding Emoji}" FontSize="18" 
                                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                                       Margin="0,8,10,0"/>

                                            <!-- Foto del jugador -->
                                            <Border Width="105" Height="105" VerticalAlignment="Bottom" Margin="0,0,0,5">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding Model.Jugador_imagen}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>

                                            <!-- Días restantes -->
                                            <Border Background="#80000000" CornerRadius="4"
                                                    HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                                                    Padding="0,2">
                                                <TextBlock Text="{Binding DiasTexto, StringFormat='⏱ {0}'}"
                                                           Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- ─── NOMBRE ─── -->
                                    <StackPanel Grid.Row="1" Margin="8,8,8,5">
                                        <TextBlock Text="{Binding Model.Jugador_nombre}"
                                                   Foreground="White" FontSize="13"
                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Model.Jugador_apellido}"
                                                   Foreground="#AAAAAA" FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- ─── ESTADÍSTICAS ─── -->
                                    <Border Grid.Row="2" Margin="10,0" Background="#08FFFFFF" CornerRadius="8" Padding="6,4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="AFINIDAD" Foreground="#666666" FontSize="7" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Model.Jugador_afinidad}" Foreground="{Binding ColorBorde}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="POSICIÓN" Foreground="#666666" FontSize="7" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Model.Jugador_posicion}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="PRECIO" Foreground="#666666" FontSize="7" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding PrecioFormato}" Foreground="#FFD700" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="CLÁUSULA" Foreground="#666666" FontSize="7" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding ClausulaFormato}" Foreground="#999999" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- ─── EQUIPO ─── -->
                                    <Border Grid.Row="3" Margin="8,8,8,10" Background="#15FFFFFF" CornerRadius="6" Padding="4">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Ellipse Width="14" Height="14" Margin="0,0,5,0">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding Model.Equipo_escudo}" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Model.Equipo_nombre}"
                                                       Foreground="#999999" FontSize="9"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════ PAGINACIÓN ══════════════════════ -->
        <Border Grid.Row="3" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="◀  Anterior"
                        Style="{StaticResource PaginaBtn}"
                        Command="{Binding PaginaAnteriorCommand}"
                        HorizontalAlignment="Left"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding InfoPagina}"
                           Foreground="White" FontSize="13"
                           FontFamily="Montserrat" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="20,0"/>

                <Button Grid.Column="2" Content="Siguiente  ▶"
                        Style="{StaticResource PaginaBtn}"
                        Command="{Binding PaginaSiguienteCommand}"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>
        </Grid>

        <!-- ══════════════════════ VISTA DE DETALLES ══════════════════════ -->
        <Grid Visibility="{Binding IsDetailVisible}" Background="#E6101010">
            <!-- Botón volver -->
            <Button HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20"
                    Command="{Binding BackToListCommand}"
                    Content="🡠 VOLVER AL MERCADO" Background="Transparent" Foreground="White" 
                    BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand"
                    Panel.ZIndex="10"/>

            <!-- ScrollViewer para contenido largo -->
            <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="0,60,0,0">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,50">

                    <!-- ════════ SECCIÓN PRINCIPAL: IMAGEN + INFO ════════ -->
                    <Border Width="900" Background="#15FFFFFF" CornerRadius="15" Padding="30" Margin="0,0,0,30" 
                            BorderBrush="#30FFFFFF" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- COLUMNA IZQUIERDA: Imagen grande -->
                            <StackPanel Grid.Column="0">
                                <!-- Foto del jugador -->
                                <Border Width="280" Height="350" CornerRadius="15"
                                        BorderBrush="{Binding SelectedAnuncio.ColorBorde}" BorderThickness="3">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" ShadowDepth="5" BlurRadius="20" Opacity="0.8"/>
                                    </Border.Effect>
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding SelectedAnuncio.Model.Jugador_imagen}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <!-- Info bajo la imagen -->
                                <Border Background="#20FFFFFF" CornerRadius="10" Padding="20" Margin="0,15,0,0">
                                    <StackPanel>
                                        <!-- Equipo -->
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="EQUIPO" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding SelectedAnuncio.Model.Equipo_nombre}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- Posición -->
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="POSICIÓN" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding SelectedAnuncio.Model.Jugador_posicion}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- Afinidad/Elemento -->
                                        <StackPanel>
                                            <TextBlock Text="ELEMENTO" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding SelectedAnuncio.Model.Jugador_afinidad}" 
                                                       Foreground="{Binding SelectedAnuncio.ColorBorde}" FontSize="16" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- COLUMNA DERECHA: Información -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                <!-- Nombre y Apellido -->
                                <StackPanel Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedAnuncio.Model.Jugador_nombre}" 
                                                   Foreground="White" FontSize="48" FontWeight="Bold" 
                                                   FontFamily="Montserrat" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding SelectedAnuncio.Model.Jugador_apellido}" 
                                                   Foreground="#CCCCCC" FontSize="48" FontWeight="Light" 
                                                   FontFamily="Montserrat"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Descripción / Datos principales -->
                                <Border Background="#20FFFFFF" CornerRadius="10" Padding="20" Margin="0,15,0,20">
                                    <StackPanel>
                                        <!-- Precio y Cláusula lado a lado -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Precio de Club -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="PRECIO DE CLUB" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                                <Border Background="#30FFD700" CornerRadius="6" Padding="10">
                                                    <TextBlock Text="{Binding SelectedAnuncio.PrecioFormato}" 
                                                               Foreground="#FFD700" FontSize="20" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- Cláusula de Rescisión -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="CLÁUSULA DE RESCISIÓN" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                                <Border Background="#30CCCCCC" CornerRadius="6" Padding="10">
                                                    <TextBlock Text="{Binding SelectedAnuncio.ClausulaFormato}" 
                                                               Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Tiempo restante -->
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="TIEMPO RESTANTE" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <Border Background="#30FF6B35" CornerRadius="6" Padding="10">
                                                <TextBlock Text="{Binding SelectedAnuncio.DiasTexto}" 
                                                           Foreground="#FF6B35" FontSize="16" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Fecha fin -->
                                        <StackPanel>
                                            <TextBlock Text="FECHA FIN DEL ANUNCIO" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding SelectedAnuncio.Model.Fecha_fin, StringFormat='dd/MM/yyyy'}" 
                                                       Foreground="White" FontSize="14"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ════════ SECCIÓN NEGOCIACIÓN: OPCIONES DE COMPRA ════════ -->
                    <Border Width="900" Background="#25000000" CornerRadius="15" Padding="30" Margin="0,0,0,30" 
                            BorderBrush="#80FF6B35" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="NEGOCIACIÓN" Foreground="#FF6B35" FontSize="24" 
                                       FontWeight="Bold" FontFamily="Montserrat" Margin="0,0,0,20"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Opción 1: Precio de Club -->
                                <Border Grid.Column="0" Background="#15FFFFFF" CornerRadius="12" 
                                        BorderBrush="#80FFD700" BorderThickness="2" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="💰 PRECIO DE CLUB" Foreground="#FFD700" 
                                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                        <TextBlock Text="{Binding SelectedAnuncio.PrecioFormato}" 
                                                   Foreground="White" FontSize="32" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                        <Button Command="{Binding ComprarPorPrecioCommand}"
                                                Content="COMPRAR AHORA" 
                                                Background="#FFD700" Foreground="Black" FontWeight="Bold"
                                                Padding="15,12" Height="45" Cursor="Hand" FontSize="14">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <TextBlock Text="Precio establecido por el club propietario" 
                                                   Foreground="#AAAAAA" FontSize="11" 
                                                   TextAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Opción 2: Cláusula de Rescisión -->
                                <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="12" 
                                        BorderBrush="#805C8C6A" BorderThickness="2" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="⚖️ CLÁUSULA DE RESCISIÓN" Foreground="#5C8C6A" 
                                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                        <TextBlock Text="{Binding SelectedAnuncio.ClausulaFormato}" 
                                                   Foreground="White" FontSize="32" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                        <Button Command="{Binding ComprarPorClausulaCommand}"
                                                Content="ACTIVAR CLÁUSULA" 
                                                Background="#5C8C6A" Foreground="White" FontWeight="Bold"
                                                Padding="15,12" Height="45" Cursor="Hand" FontSize="14">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <TextBlock Text="Derecho contractual siempre disponible" 
                                                   Foreground="#AAAAAA" FontSize="11" 
                                                   TextAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════ DIÁLOGO DE CONFIRMACIÓN ══════════════════════ -->
        <Grid Visibility="{Binding IsConfirmDialogVisible}" Panel.ZIndex="999">
            <!-- Overlay oscuro -->
            <Border Background="#AA000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelarCompraCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- Diálogo -->
            <Border Width="500" Height="Auto" Background="#1E1E1E" 
                    BorderBrush="#FF6B35" BorderThickness="3" CornerRadius="16"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.8" Color="Black"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Título -->
                    <TextBlock Text="{Binding ConfirmTitle}" Foreground="#FF6B35" FontSize="22" 
                               FontWeight="Bold" Margin="0,0,0,15" TextAlignment="Center" 
                               FontFamily="Montserrat" TextWrapping="Wrap"/>

                    <!-- Mensaje -->
                    <TextBlock Text="{Binding ConfirmMessage}" Foreground="White" FontSize="14" 
                               TextAlignment="Center" Margin="0,0,0,25" TextWrapping="Wrap" LineHeight="22"/>

                    <!-- Información de monto -->
                    <Border Background="#30FFD700" CornerRadius="10" Padding="15" Margin="0,0,0,25" 
                            BorderBrush="#60FFD700" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="MONTO A TRANSFERIR" Foreground="#FFD700" FontSize="12" 
                                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ConfirmMontoFormato}" Foreground="White" FontSize="28" 
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Botones -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Botón Cancelar -->
                        <Button Grid.Column="0" Command="{Binding CancelarCompraCommand}"
                                Content="CANCELAR" 
                                Background="#30FFFFFF" Foreground="White" FontWeight="Bold"
                                Padding="15,12" Height="45" BorderThickness="0" Cursor="Hand" FontSize="14">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <!-- Botón Aceptar -->
                        <Button Grid.Column="2" Command="{Binding AceptarCompraCommand}"
                                Content="CONFIRMAR COMPRA" 
                                Background="#FF6B35" Foreground="White" FontWeight="Bold"
                                Padding="15,12" Height="45" BorderThickness="0" Cursor="Hand" FontSize="14">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
