<Window x:Class="InaManager.View.BancoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:InaManager.ViewModel"
        mc:Ignorable="d" 
        Title="Banco - INA Ecosystem" Height="700" Width="1200"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.DataContext>
        <vm:BancoViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Color x:Key="winBackColor1">#042e04</Color>
        <Color x:Key="winBackColor2">#684007</Color>
        <Color x:Key="winBackColor3">#6c0b0b</Color>
        <Color x:Key="winBorderColor1">#042e04</Color>
        <Color x:Key="winBorderColor2">#684007</Color>
        <Color x:Key="winBorderColor3">#6c0b0b</Color>
    </Window.Resources>

    <Border CornerRadius="20" BorderThickness="5">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource winBorderColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBorderColor2}" Offset="0.5"/>
                <GradientStop Color="{StaticResource winBorderColor3}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Border.Background>
            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                <GradientStop Color="{StaticResource winBackColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBackColor2}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CONTENIDO PRINCIPAL -->
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- BARRA SUPERIOR -->
                <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#30FFFFFF" Padding="20,0,20,15">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🏦 BANCO" FontSize="18" FontWeight="Bold" Foreground="#1E6EBF" 
                                       FontFamily="Montserrat" VerticalAlignment="Center"/>
                            <TextBlock Text="Gestión de Finanzas" FontSize="12" Foreground="#AAAAAA" 
                                       FontFamily="Montserrat" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Command="{Binding VolverAlHubCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" Background="Transparent" Padding="10">
                                            <TextBlock Text="← Volver" FontSize="12" Foreground="#AAAAAA" 
                                                       FontFamily="Montserrat" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#20FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CONTENIDO CENTRAL -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">

                    <!-- SALDO PRINCIPAL -->
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,40">
                        <TextBlock Text="Saldo Disponible" FontSize="14" Foreground="#AAAAAA" 
                                   FontFamily="Montserrat" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BancoDatos.Saldo, StringFormat=C2}" 
                                   FontSize="56" FontWeight="Bold" Foreground="#1E6EBF" 
                                   FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" ShadowDepth="3" BlurRadius="10" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <!-- TARJETA CON DATOS -->
                    <Border Padding="40" Margin="0,20,0,0"
                            Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5" CornerRadius="15"
                            MaxWidth="500">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.4"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- NOMBRE -->
                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="Propietario" FontSize="11" Foreground="#AAAAAA" 
                                           FontFamily="Montserrat" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding BancoDatos.NombrePropietario}" 
                                           FontSize="18" Foreground="White" FontFamily="Montserrat" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- TIPO DE CUENTA -->
                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="Tipo de Cuenta" FontSize="11" Foreground="#AAAAAA" 
                                           FontFamily="Montserrat" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding BancoDatos.TipoCuenta}" 
                                           FontSize="14" Foreground="White" FontFamily="Montserrat" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- NÚMERO DE CUENTA -->
                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="Número de Cuenta" FontSize="11" Foreground="#AAAAAA" 
                                           FontFamily="Montserrat" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding BancoDatos.NumeroCuenta}" 
                                           FontSize="14" Foreground="#1E6EBF" FontFamily="Courier New" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- IBAN -->
                            <StackPanel Margin="0,0,0,30">
                                <TextBlock Text="IBAN" FontSize="11" Foreground="#AAAAAA" 
                                           FontFamily="Montserrat" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding BancoDatos.IBAN}" 
                                           FontSize="14" Foreground="#1E6EBF" FontFamily="Courier New" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- BOTÓN DE TRANSFERENCIA -->
                            <Button Command="{Binding TransferirDineroCommand}" 
                                    Background="#1E6EBF" Foreground="White" 
                                    Padding="15,12" FontSize="13" FontWeight="Bold" 
                                    Cursor="Hand"
                                    BorderThickness="0" FontFamily="Montserrat">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                                CornerRadius="8" Padding="15,12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#155A9E"/>
                                                <Setter TargetName="BtnBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#1E6EBF" ShadowDepth="2" BlurRadius="8" Opacity="0.6"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="💸 " FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Transferir Dinero"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- FOOTER -->
                <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#30FFFFFF" Padding="20,15,20,0" Margin="0,40,0,0">
                    <Grid>
                        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                                   Foreground="#666666" FontSize="11" FontFamily="Montserrat">
                            <Run Text="Banco INA  ·  v1.0"/>
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="#666666" FontSize="11" FontFamily="Montserrat">
                            <Run Text="Saldo actualizado"/>
                        </TextBlock>
                    </Grid>
                </Border>

            </Grid>

        </Grid>
    </Border>
</Window>
