<UserControl x:Class="InaManager.View.InversionesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Botones de Pestañas -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" Padding="10,6" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#1AFFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,10,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER DE PESTAÑAS ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16" HorizontalAlignment="Center">
            <Border Background="#0AFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="10" Padding="4">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="📊 Mercado" Style="{StaticResource TabButtonStyle}" Width="120"
                                 Command="{Binding TabMercadoCommand}"
                                 IsChecked="{Binding IsTabMercado, Mode=OneWay}"/>
                    <RadioButton Content="📁 Mi Cartera" Style="{StaticResource TabButtonStyle}" Width="120"
                                 Command="{Binding TabCarteraCommand}"
                                 IsChecked="{Binding IsTabCartera, Mode=OneWay}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Mensaje Global -->
        <Border Grid.Row="1" VerticalAlignment="Top" Visibility="{Binding MostrarMensaje, Converter={StaticResource BoolToVis}}"
                CornerRadius="10" Padding="14,10" Margin="0,0,0,10" Panel.ZIndex="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#30FF5555"/>
                    <Setter Property="BorderBrush" Value="#60FF5555"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MensajeExitoso}" Value="True">
                            <Setter Property="Background" Value="#2200CC77"/>
                            <Setter Property="BorderBrush" Value="#6000CC77"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding Mensaje}" FontSize="12" FontFamily="Montserrat"
                       Foreground="White" TextWrapping="Wrap" HorizontalAlignment="Center"/>
        </Border>

        <!-- ========================================================================= -->
        <!-- PESTAÑA: MERCADO -->
        <!-- ========================================================================= -->
        <Grid Grid.Row="1" Visibility="{Binding IsTabMercado, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de Mercado -->
            <Border Grid.Column="0" CornerRadius="14" Background="#0AFFFFFF"
                    BorderBrush="#15FFFFFF" BorderThickness="1" Padding="6">
                <ListView ItemsSource="{Binding Activos}"
                          SelectedItem="{Binding ActivoSeleccionado}"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="10" Padding="12,10" Margin="0,3">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#201E6EBF"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#501E6EBF"/>
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="#1A1E6EBF">
                                    <TextBlock Text="{Binding Model.IconoEmoji}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Model.Nombre}" FontSize="14" FontWeight="SemiBold" Foreground="White" FontFamily="Montserrat"/>
                                    <TextBlock Text="{Binding Model.Simbolo}" FontSize="11" Foreground="#555555" FontFamily="Montserrat" Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PrecioActual, StringFormat=C2}" FontSize="14" FontWeight="Bold" Foreground="White" FontFamily="Montserrat" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding VariacionTexto, Mode=OneWay}" FontSize="11" FontFamily="Montserrat" HorizontalAlignment="Right" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FF5555"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EsPositivo}" Value="True">
                                                        <Setter Property="Foreground" Value="#00CC77"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Panel de Compra -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border CornerRadius="14" Background="#0AFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" Padding="20,18" Margin="0,45,0,0"
                            Visibility="{Binding HayActivoSeleccionado, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="40" Height="40" CornerRadius="20" Background="#1A1E6EBF" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding ActivoSeleccionado.Model.IconoEmoji}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ActivoSeleccionado.Model.Nombre}" FontSize="16" FontWeight="Bold" Foreground="White" FontFamily="Montserrat"/>
                                    <TextBlock FontSize="11" Foreground="#888888" FontFamily="Montserrat" Margin="0,2,0,0">
                                        <Run Text="Precio actual: "/>
                                        <Run Text="{Binding ActivoSeleccionado.PrecioActual, StringFormat=C2}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="EUROS A INVERTIR" FontSize="10" FontWeight="Bold" Foreground="#555555" FontFamily="Montserrat" Margin="0,0,0,6"/>
                            <Border CornerRadius="8" Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" Padding="12,10" Margin="0,0,0,10">
                                <TextBox Text="{Binding EurosAInvertir, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White"
                                         FontFamily="Montserrat" FontSize="15" FontWeight="SemiBold" CaretBrush="White"/>
                            </Border>

                            <Border CornerRadius="8" Background="#0AFFFFFF" Padding="12,8" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Recibirás: " FontSize="12" Foreground="#888888" FontFamily="Montserrat" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="#1E8FFF" FontFamily="Montserrat" VerticalAlignment="Center">
                                        <Run Text="{Binding UnidadesARecibir, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding ActivoSeleccionado.Model.Simbolo}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Button Command="{Binding ComprarCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#00AA55" CornerRadius="10" Padding="0,13">
                                            <Border.Effect><DropShadowEffect Color="#00AA55" ShadowDepth="0" BlurRadius="12" Opacity="0.4"/></Border.Effect>
                                            <TextBlock Text="💰 Comprar" FontSize="14" FontWeight="Bold" Foreground="White" FontFamily="Montserrat" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#008844"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>


                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ========================================================================= -->
        <!-- PESTAÑA: CARTERA -->
        <!-- ========================================================================= -->
        <Grid Grid.Row="1" Visibility="{Binding IsTabCartera, Converter={StaticResource BoolToVis}}">
            
            <Border CornerRadius="12" Background="#08FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" Padding="16,40" VerticalAlignment="Top" Margin="0,45,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HayCartera}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📭" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Tu cartera está vacía." FontSize="16" FontWeight="SemiBold" Foreground="White" FontFamily="Montserrat" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ve al mercado para realizar tu primera inversión." FontSize="12" Foreground="#888888" FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,45,0,0">
                <ItemsControl ItemsSource="{Binding Cartera}" Visibility="{Binding HayCartera, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Background="#0AFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" Padding="18,16" Margin="10" Width="380">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Fila 1: Cabecera Activo -->
                                    <Grid Grid.Row="0" Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="44" Height="44" CornerRadius="22" Background="#1A1E6EBF" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Model.IconoEmoji}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Model.NombreActivo}" FontSize="16" FontWeight="Bold" Foreground="White" FontFamily="Montserrat"/>
                                                <TextBlock FontSize="12" Foreground="#888888" FontFamily="Montserrat" Margin="0,2,0,0">
                                                    <Run Text="{Binding Model.Cantidad, StringFormat=F6}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Model.SimboloActivo}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ValorActual, Mode=OneWay, StringFormat=C2}" FontSize="18" FontWeight="Bold" Foreground="White" FontFamily="Montserrat" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding GananciaPerdidaTexto, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" FontFamily="Montserrat" HorizontalAlignment="Right" Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EsGanancia}" Value="True">
                                                                <Setter Property="Foreground" Value="#00CC77"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Fila 2: Detalles extra -->
                                    <Border Grid.Row="1" CornerRadius="8" Background="#05FFFFFF" Padding="12,10" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Precio de compra:" FontSize="10" Foreground="#666666" FontFamily="Montserrat"/>
                                                <TextBlock Text="{Binding Model.PrecioCompra, StringFormat=C2}" FontSize="12" FontWeight="SemiBold" Foreground="#AAAAAA" FontFamily="Montserrat" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Rendimiento:" FontSize="10" Foreground="#666666" FontFamily="Montserrat"/>
                                                <TextBlock Text="{Binding GananciaPctTexto, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" FontFamily="Montserrat" Margin="0,2,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#FF5555"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding EsGanancia}" Value="True">
                                                                    <Setter Property="Foreground" Value="#00CC77"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Fila 3: Botones y Formulario de Venta -->
                                    <StackPanel Grid.Row="2">
                                        <!-- Botón Operar (Abrir formulario) -->
                                        <Button Cursor="Hand" Command="{Binding DataContext.ToggleFormVentaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MostrarFormVenta}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="#15FFFFFF" CornerRadius="8" Padding="0,10">
                                                        <TextBlock Text="Vender..." FontSize="13" FontWeight="SemiBold" Foreground="White" FontFamily="Montserrat" HorizontalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/></Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- Formulario Desplegable de Venta -->
                                        <Border Visibility="{Binding MostrarFormVenta, Converter={StaticResource BoolToVis}}" Background="#1A000000" CornerRadius="10" Padding="12" BorderThickness="1" BorderBrush="#20FFFFFF">
                                            <StackPanel>
                                                <TextBlock Text="Cantidad a vender:" FontSize="11" Foreground="#888888" FontFamily="Montserrat" Margin="0,0,0,6"/>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="6" Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="8,6" Margin="0,0,8,0">
                                                        <TextBox Text="{Binding CantidadVender, UpdateSourceTrigger=PropertyChanged}"
                                                                 Background="Transparent" BorderThickness="0" Foreground="White"
                                                                 FontFamily="Montserrat" FontSize="14" FontWeight="SemiBold" CaretBrush="White"/>
                                                    </Border>
                                                    <Button Grid.Column="1" Cursor="Hand" Command="{Binding DataContext.VenderTodoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="#301E8FFF" CornerRadius="6" Padding="12,6" BorderThickness="1" BorderBrush="#501E8FFF">
                                                                    <TextBlock Text="MÁX" FontSize="11" FontWeight="Bold" Foreground="#1E8FFF" FontFamily="Montserrat" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#501E8FFF"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Margin="0,0,4,0" Cursor="Hand" Command="{Binding DataContext.ToggleFormVentaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="0,10" BorderThickness="1" BorderBrush="#40FFFFFF">
                                                                    <TextBlock Text="Cancelar" FontSize="12" FontWeight="SemiBold" Foreground="#AAAAAA" FontFamily="Montserrat" HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Grid.Column="1" Margin="4,0,0,0" Cursor="Hand" Command="{Binding DataContext.VenderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="#FF4444" CornerRadius="6" Padding="0,10">
                                                                    <TextBlock Text="Confirmar Venta" FontSize="12" FontWeight="Bold" Foreground="White" FontFamily="Montserrat" HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#CC3333"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
