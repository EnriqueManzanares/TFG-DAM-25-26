<UserControl x:Class="InaManager.View.TransferenciaBancariaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="60,40,60,50" HorizontalAlignment="Stretch" VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO (Ocupa ambas columnas) -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,35">
            <TextBlock Text="💸 Nueva Transferencia" FontSize="32" FontWeight="Bold"
                       Foreground="#1E6EBF" FontFamily="Montserrat" Margin="0,0,0,6"/>
            <TextBlock Text="Envía dinero de forma rápida y segura entre cuentas del sistema"
                       FontSize="14" Foreground="#AAAAAA" FontFamily="Montserrat"/>
        </StackPanel>

        <!-- COLUMNA IZQUIERDA: FORMULARIO -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,50,0">
            <!-- IBAN DESTINATARIO -->
            <StackPanel Margin="0,0,0,25">
                <TextBlock Text="IBAN del Destinatario" FontSize="13" Foreground="#AAAAAA"
                           FontFamily="Montserrat" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBox Text="{Binding IbanDestinatario, UpdateSourceTrigger=PropertyChanged}"
                         Background="#10FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5"
                         Foreground="White" Padding="15,14" FontSize="14" FontFamily="Courier New"
                         ToolTip="Ej: ES9121000418450200051332">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd" CornerRadius="10" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
                <TextBlock Text="{Binding ErrorIban}" Foreground="#FF6B6B"
                           FontSize="11" Margin="0,6,0,0" FontFamily="Montserrat"
                           Visibility="{Binding MostrarErrorIban, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- MONTO -->
            <StackPanel Margin="0,0,0,25">
                <TextBlock Text="Monto a Transferir" FontSize="13" Foreground="#AAAAAA"
                           FontFamily="Montserrat" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBox Text="{Binding Monto, UpdateSourceTrigger=PropertyChanged}"
                         Background="#10FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5"
                         Foreground="White" Padding="15,14" FontSize="14" FontFamily="Montserrat"
                         ToolTip="Ingresa un monto válido">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd" CornerRadius="10" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
                <TextBlock Text="{Binding ErrorMonto}" Foreground="#FF6B6B"
                           FontSize="11" Margin="0,6,0,0" FontFamily="Montserrat"
                           Visibility="{Binding MostrarErrorMonto, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- CONCEPTO -->
            <StackPanel Margin="0,0,0,25">
                <TextBlock Text="Concepto (Opcional)" FontSize="13" Foreground="#AAAAAA"
                           FontFamily="Montserrat" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBox Text="{Binding Concepto, UpdateSourceTrigger=PropertyChanged}"
                         Background="#10FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5"
                         Foreground="White" Padding="15,14" FontSize="14" FontFamily="Montserrat"
                         ToolTip="Ej: Pago de servicios">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd" CornerRadius="10" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
            </StackPanel>

            <!-- MENSAJE DE ESTADO (Debajo del formulario para visibilidad) -->
            <Border Background="#10FFFFFF" CornerRadius="8" Padding="15,10" Margin="0,10,0,0"
                    Visibility="{Binding MostrarMensaje, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding Mensaje}" FontSize="12" TextWrapping="Wrap"
                           FontFamily="Montserrat">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF6B6B"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TransferenciaExitosa}" Value="True">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- COLUMNA DERECHA: INFORMACIÓN Y RESUMEN -->
        <StackPanel Grid.Row="1" Grid.Column="1">
            <!-- SALDO ACTUAL -->
            <Border Padding="25" Margin="0,0,0,25"
                    Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5" CornerRadius="18">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="SALDO DISPONIBLE" FontSize="10" Foreground="#AAAAAA"
                               FontFamily="Montserrat" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SaldoActual, StringFormat=C2}"
                               FontSize="34" FontWeight="Bold" Foreground="#1E6EBF"
                               FontFamily="Montserrat" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- RESUMEN -->
            <Border Padding="25"
                    Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5" CornerRadius="18">
                <StackPanel>
                    <TextBlock Text="RESUMEN DE OPERACIÓN" FontSize="10" FontWeight="Bold"
                               Foreground="White" FontFamily="Montserrat" Margin="0,0,0,20"/>
                    
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Monto a enviar" Foreground="#AAAAAA" FontSize="13" FontFamily="Montserrat"/>
                        <TextBlock HorizontalAlignment="Right" Text="{Binding Monto, StringFormat=C2}"
                                   Foreground="White" FontSize="13" FontWeight="SemiBold" FontFamily="Montserrat"/>
                    </Grid>

                    <Separator Background="#20FFFFFF" Margin="0,5,0,15"/>

                    <Grid>
                        <TextBlock Text="Saldo resultante" Foreground="#AAAAAA" FontSize="13" FontFamily="Montserrat"/>
                        <TextBlock HorizontalAlignment="Right" Text="{Binding SaldoDespues, StringFormat=C2}"
                                   Foreground="#1E6EBF" FontSize="14" FontWeight="Bold" FontFamily="Montserrat"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="* Las transferencias internas son instantáneas y no tienen comisión."
                       FontSize="11" Foreground="#555555" FontFamily="Montserrat" Margin="0,20,0,0"
                       FontStyle="Italic" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- FOOTER: BOTONES -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,40,0,0" Padding="0,20,0,0"
                BorderThickness="0,1,0,0" BorderBrush="#15FFFFFF">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancelar -->
                <Button Command="{Binding CancelarCommand}"
                        Cursor="Hand" Margin="0,0,15,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="Transparent"
                                    BorderBrush="#40FFFFFF" BorderThickness="1.5" CornerRadius="10" Padding="30,14">
                                <TextBlock Text="Cancelar" FontSize="13" FontWeight="Bold"
                                           Foreground="#AAAAAA" FontFamily="Montserrat"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#20FFFFFF"/>
                                    <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#60FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Confirmar -->
                <Button Command="{Binding ConfirmarTransferenciaCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="#1E6EBF" CornerRadius="10" Padding="35,14">
                                <TextBlock Text="Confirmar Transferencia" FontSize="13" FontWeight="Bold"
                                           Foreground="White" FontFamily="Montserrat"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#155A9E"/>
                                    <Setter TargetName="BtnBorder" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#1E6EBF" ShadowDepth="0" BlurRadius="15" Opacity="0.6"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
