<Window x:Class="InaManager.View.TransferenciaBancariaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:InaManager.ViewModel"
        mc:Ignorable="d" 
        Title="Transferencia Bancaria" Height="600" Width="600"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.DataContext>
        <vm:TransferenciaBancariaViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Color x:Key="winBackColor1">#042e04</Color>
        <Color x:Key="winBackColor2">#684007</Color>
        <Color x:Key="winBorderColor1">#042e04</Color>
        <Color x:Key="winBorderColor2">#684007</Color>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="20" BorderThickness="5">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource winBorderColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBorderColor2}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Border.Background>
            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                <GradientStop Color="{StaticResource winBackColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBackColor2}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- BARRA SUPERIOR -->
            <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#30FFFFFF" Padding="20,15,20,15">
                <Grid>
                    <TextBlock Text="💸 Nueva Transferencia" FontSize="16" FontWeight="Bold" 
                               Foreground="#1E6EBF" FontFamily="Montserrat" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- CONTENIDO PRINCIPAL -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40,30,40,30">
                    <StackPanel.Resources>
                        <Style TargetType="StackPanel">
                            <Setter Property="Margin" Value="0,0,0,25"/>
                        </Style>
                    </StackPanel.Resources>

                    <!-- SALDO ACTUAL -->
                    <StackPanel>
                        <TextBlock Text="Tu Saldo Actual" FontSize="12" Foreground="#AAAAAA" 
                                   FontFamily="Montserrat" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SaldoActual, StringFormat=C2}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#1E6EBF" 
                                   FontFamily="Montserrat" Margin="0,8,0,0"/>
                    </StackPanel>

                    <Separator Background="#30FFFFFF" Height="1" Margin="0,0,0,25"/>

                    <!-- IBAN DESTINATARIO -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="IBAN del Destinatario" FontSize="12" Foreground="#AAAAAA" 
                                   FontFamily="Montserrat" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="IbanDestinatarioTextBox" 
                                 Text="{Binding IbanDestinatario, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#10FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5" 
                                 Foreground="White" Padding="15,12" FontSize="13" 
                                 FontFamily="Courier New"
                                 ToolTip="Ej: ES9121000418450200051332">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border x:Name="Bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                        <TextBlock Text="{Binding ErrorIban}" Foreground="#FF6B6B" 
                                   FontSize="11" Margin="0,5,0,0" FontFamily="Montserrat"
                                   Visibility="{Binding MostrarErrorIban, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- MONTO -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Monto a Transferir" FontSize="12" Foreground="#AAAAAA" 
                                   FontFamily="Montserrat" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="MontoTextBox" 
                                 Text="{Binding Monto, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#10FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5" 
                                 Foreground="White" Padding="15,12" FontSize="13" 
                                 FontFamily="Montserrat"
                                 ToolTip="Ingresa un monto válido">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border x:Name="Bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                        <TextBlock Text="{Binding ErrorMonto}" Foreground="#FF6B6B" 
                                   FontSize="11" Margin="0,5,0,0" FontFamily="Montserrat"
                                   Visibility="{Binding MostrarErrorMonto, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- CONCEPTO -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Concepto (Opcional)" FontSize="12" Foreground="#AAAAAA" 
                                   FontFamily="Montserrat" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="ConceptoTextBox" 
                                 Text="{Binding Concepto, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#10FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5" 
                                 Foreground="White" Padding="15,12" FontSize="13" 
                                 FontFamily="Montserrat"
                                 ToolTip="Ej: Pago de servicios">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border x:Name="Bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                    </StackPanel>

                    <!-- RESUMEN -->
                    <Border Padding="20" Margin="0,10,0,0"
                            Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5" CornerRadius="12">
                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="Resumen de Transferencia" FontSize="13" FontWeight="Bold" 
                                       Foreground="White" FontFamily="Montserrat" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Monto:" Foreground="#AAAAAA" FontSize="11" FontFamily="Montserrat"/>
                                <TextBlock Grid.Column="1" Text="{Binding Monto, StringFormat=C2}" 
                                           Foreground="#1E6EBF" FontSize="11" FontWeight="Bold" FontFamily="Montserrat"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Saldo después:" Foreground="#AAAAAA" FontSize="11" FontFamily="Montserrat"/>
                                <TextBlock Grid.Column="1" Text="{Binding SaldoDespues, StringFormat=C2}" 
                                           Foreground="#1E6EBF" FontSize="11" FontWeight="Bold" FontFamily="Montserrat"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- MENSAJES -->
                    <TextBlock Text="{Binding Mensaje}" Foreground="#FF6B6B" 
                               FontSize="12" TextWrapping="Wrap" FontFamily="Montserrat"
                               Margin="0,25,0,0"
                               Visibility="{Binding MostrarMensaje, Converter={StaticResource BoolToVis}}"/>

                </StackPanel>
            </ScrollViewer>

            <!-- FOOTER CON BOTONES -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#30FFFFFF" Padding="40,15,40,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- BOTÓN CANCELAR -->
                    <Button Command="{Binding CancelarCommand}" 
                            Background="Transparent" Foreground="#AAAAAA" 
                            Padding="20,10" FontSize="12" FontWeight="Bold" 
                            Cursor="Hand" BorderThickness="1.5"
                            BorderBrush="#30FFFFFF" FontFamily="Montserrat" Margin="0,0,12,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="20,10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        Cancelar
                    </Button>

                    <!-- BOTÓN CONFIRMAR -->
                    <Button Command="{Binding ConfirmarTransferenciaCommand}" 
                            Background="#1E6EBF" Foreground="White" 
                            Padding="20,10" FontSize="12" FontWeight="Bold" 
                            Cursor="Hand" BorderThickness="0" FontFamily="Montserrat">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="20,10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#155A9E"/>
                                        <Setter TargetName="BtnBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#1E6EBF" ShadowDepth="2" BlurRadius="8" Opacity="0.6"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        Confirmar Transferencia
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
