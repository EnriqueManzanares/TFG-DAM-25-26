<Window x:Class="InaManager.View.MercadoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:view="clr-namespace:InaManager.View"
        Title="Mercado de Fichajes - INA Ecosystem"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Images/logoInaManager.png"
        MouseDown="Window_MouseDown"
        FontFamily="Montserrat">

    <Border CornerRadius="20" BorderThickness="3">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#042e04" Offset="0"/>
                <GradientStop Color="#684007" Offset="0.5"/>
                <GradientStop Color="#6c0b0b" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                <GradientStop Color="#0D0D1A" Offset="0"/>
                <GradientStop Color="#1A1A2E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Barra de título -->
                <RowDefinition Height="48"/>
                <!-- Contenido principal -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════ BARRA DE TÍTULO ══════════ -->
            <Border Grid.Row="0" Background="#18FFFFFF"
                    CornerRadius="20,20,0,0" BorderThickness="0,0,0,1"
                    BorderBrush="#25FFFFFF">
                <Grid Margin="20,0">
                    <!-- Logo + nombre -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚽" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="MERCADO DE FICHAJES"
                                   Foreground="White" FontSize="14"
                                   FontWeight="Bold" FontFamily="Montserrat"
                                   VerticalAlignment="Center"/>
                        <Border Background="#20FFD700" CornerRadius="6"
                                Margin="14,0,0,0" Padding="8,3">
                            <TextBlock Text="INA ECOSYSTEM" Foreground="#FFD700"
                                       FontSize="9" FontFamily="Montserrat"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Botones de ventana -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="⬅ Hub" Foreground="#AAAAAA"
                                Background="Transparent" BorderThickness="0"
                                Margin="0,0,10,0" Click="BtnVolverHub_Click"
                                FontFamily="Montserrat" FontSize="12" Cursor="Hand"
                                ToolTip="Volver al selector de aplicaciones"/>
                        <Button Content="—" Foreground="White"
                                Background="Transparent" BorderThickness="0"
                                Margin="5" Click="BtnMinimizar_Click"
                                FontFamily="Montserrat" FontWeight="Bold" Cursor="Hand"/>
                        <Button Content="✕" Foreground="White"
                                Background="Transparent" BorderThickness="0"
                                Margin="5" Click="BtnCerrar_Click"
                                FontFamily="Montserrat" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════ CONTENIDO ══════════ -->
            <view:MercadoView Grid.Row="1" Margin="20,16,20,16"/>
        </Grid>
    </Border>
</Window>
