<UserControl x:Class="InaManager.View.PlantillaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:InaManager.ViewModel"
             xmlns:converters="clr-namespace:InaManager.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:PlantillaViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisConverter x:Key="BoolToVis" />
        <converters:NullToVisConverter x:Key="NullToVis" />

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#40FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#10FFFFFF"/>

            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Jugador_MouseDown"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="FichaJugadorTemplate">
            <Border Background="#E61A1A1A" BorderBrush="#60FFFFFF" BorderThickness="1" CornerRadius="4">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                </Border.Effect>
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Margin="0,0,8,0" BorderBrush="#50FFFFFF" BorderThickness="1">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding Url_imagen}" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Nombre}" Foreground="White" FontWeight="Bold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Posicion}" Foreground="#FFD700" FontSize="10" FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="{Binding Dorsal}" Foreground="#30FFFFFF" 
                               FontSize="20" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="2.5*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,5">
                    <TextBlock Text="ONCE INICIAL" FontSize="20" Foreground="White" FontWeight="Bold">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="2" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="{Binding MensajeEstado}" FontSize="12" Foreground="#FF5555" Margin="0,2,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" CornerRadius="12" BorderBrush="#40FFFFFF" BorderThickness="1" ClipToBounds="True">
                    <Grid>
                        <Image Source="/Images/CampoFutbol.png" Stretch="Fill" Opacity="0.9"/>

                        <ItemsControl ItemsSource="{Binding GridCampo}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="6" Columns="5"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#20FFFFFF" BorderThickness="0.5"
                                            AllowDrop="{Binding EsPosicionValida}"
                                            Drop="Celda_Drop"
                                            DragEnter="Celda_DragEnter"
                                            Background="Transparent"
                                            Padding="4">
                                        <Grid>
                                            <ContentControl Content="{Binding Jugador}" 
                                                            ContentTemplate="{StaticResource FichaJugadorTemplate}"
                                                            HorizontalContentAlignment="Stretch"
                                                            VerticalContentAlignment="Stretch"
                                                            Visibility="{Binding Jugador, Converter={StaticResource NullToVis}}"
                                                            PreviewMouseLeftButtonDown="Jugador_MouseDown"/>

                                            <Border BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4" Background="#30000000" IsHitTestVisible="False">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding EsPosicionValida}" Value="True"/>
                                                                    <Condition Binding="{Binding Jugador}" Value="{x:Null}"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding NombrePosicion}" Foreground="#80FFFFFF" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1" Margin="5,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="SUPLENTES" FontSize="20" Foreground="#FFD700" FontWeight="Bold" Margin="0,0,0,5"/>

                <Border Grid.Row="1" Background="#10FFFFFF" CornerRadius="8" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="5">
                    <ItemsControl ItemsSource="{Binding Banquillo}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="1" Rows="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,3" 
                                        BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="4" 
                                        Background="#05FFFFFF"
                                        AllowDrop="True"
                                        Drop="Celda_Drop"
                                        DragEnter="Celda_DragEnter">
                                    <Grid>
                                        <ContentControl Content="{Binding Jugador}" 
                                                        ContentTemplate="{StaticResource FichaJugadorTemplate}"
                                                        PreviewMouseLeftButtonDown="Jugador_MouseDown"
                                                        Visibility="{Binding Jugador, Converter={StaticResource NullToVis}}"/>

                                        <TextBlock Text="VACÍO" Foreground="#20FFFFFF" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Jugador}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <Border Grid.Row="2" Margin="0,10,0,0" Height="60"
                        Background="#20FFFFFF" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="4"
                        PreviewMouseLeftButtonDown="Mister_Click" Cursor="Hand">
                    <Grid x:Name="MisterGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Margin="10,0" BorderBrush="White" BorderThickness="1">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Entrenador.Url_imagen}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="MÍSTER" Foreground="#FFD700" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Entrenador.Nombre, TargetNullValue='Sin Asignar'}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>

                        <Popup x:Name="PopupMisters" 
                               IsOpen="{Binding MostrarSelectorMister, Mode=TwoWay}" 
                               StaysOpen="False" 
                               PlacementTarget="{Binding ElementName=MisterGrid}"
                               Placement="Top"
                               AllowsTransparency="True"
                               Focusable="True">
                            <Border Background="#252525" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" 
                                    Width="220" Padding="5" Margin="0,0,0,10">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Seleccionar Entrenador" Foreground="#FFD700" FontWeight="Bold" 
                                               Margin="5" HorizontalAlignment="Center"/>
                                    <Separator Background="#40FFFFFF" Margin="0,2,0,5"/>

                                    <ListBox ItemsSource="{Binding ListaMisters}" 
                                             Background="Transparent" 
                                             BorderThickness="0"
                                             MaxHeight="200"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             SelectionChanged="SelectorMister_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{TemplateBinding Background}" Padding="5" CornerRadius="4">
                                                                <ContentPresenter />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#40FFFFFF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="35"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding Url_imagen}" Stretch="UniformToFill"/>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Nombre}" VerticalAlignment="Center" 
                                                               Foreground="White" FontSize="13" Margin="10,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="1" Text="BANCO DE JUGADORES (RESERVAS)" 
                   FontSize="16" Foreground="#AAAAAA" FontWeight="Bold" Margin="0,15,0,5"
                   Visibility="{Binding BancoVisibility}"/>

        <Border Grid.Row="2" CornerRadius="10" Background="#15000000" BorderBrush="#30FFFFFF" BorderThickness="1"
                Visibility="{Binding BancoVisibility}">
            <DataGrid ItemsSource="{Binding Reservas}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      HeadersVisibility="Column" 
                      Background="Transparent" 
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal" 
                      HorizontalGridLinesBrush="#20FFFFFF"
                      VerticalGridLinesBrush="Transparent"
                      RowHeight="45"
                      AllowDrop="True"
                      Drop="Reservas_Drop">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Dorsal}" Width="50" Foreground="#80FFFFFF"/>

                    <DataGridTemplateColumn Header="JUGADOR" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="30" Height="30" CornerRadius="15" Margin="0,0,10,0" BorderBrush="#50FFFFFF" BorderThickness="1">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding Url_imagen}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nombre}" FontWeight="Bold" Foreground="White" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="POSICIÓN" Binding="{Binding Posicion}" Width="100" FontWeight="Bold" Foreground="#FFD700"/>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="2"
              Visibility="{Binding IsReadOnlyMode, Converter={StaticResource BoolToVis}}"
              Background="Transparent" 
              Panel.ZIndex="9999"/>

    </Grid>
</UserControl>