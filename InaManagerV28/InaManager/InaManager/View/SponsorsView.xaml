<UserControl x:Class="InaManager.View.SponsorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#40FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#30000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Visibility="{Binding IsListVisible}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="PATROCINADORES Y SOCIOS" FontSize="24" Foreground="White" FontWeight="Bold" FontFamily="Montserrat" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" ShadowDepth="2" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding NewSponsorCommand}"
                        Content="+ AÑADIR PATROCINADOR"
                        Background="#FFD700" Foreground="Black" FontWeight="Bold" 
                        Padding="15,5" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <Border Grid.Row="1" CornerRadius="15" Background="#15000000" BorderBrush="#30FFFFFF" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Sponsors}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#20FFFFFF"
                          VerticalGridLinesBrush="Transparent" RowBackground="Transparent" RowHeight="80">

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="LOGO" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Url_Logo}" Height="50" Stretch="Uniform"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="EMPRESA" Binding="{Binding Nombre_Empresa}" Width="*" FontWeight="Bold" Foreground="#FFD700"/>
                        <DataGridTextColumn Header="SECTOR" Binding="{Binding Sector}" Width="150"/>
                        <DataGridTextColumn Header="APORTE (€)" Binding="{Binding Aporte_Economico, StringFormat={}{0:C}}" Width="120"/>
                        <DataGridTextColumn Header="FIN CONTRATO" Binding="{Binding Fecha_Fin, StringFormat=d}" Width="120"/>

                        <DataGridTemplateColumn Header="ACCIONES" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="EDITAR" 
                                                Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Background="#40FFFFFF" Foreground="White" BorderThickness="0" 
                                                Padding="5,2" Margin="0,0,5,0" Cursor="Hand" FontWeight="Bold" FontSize="10">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>

                                        <Button Content="X" 
                                                Command="{Binding DataContext.DeleteSponsorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding Id_Sponsor}"
                                                Background="#B71C1C" Foreground="White" BorderThickness="0" 
                                                Padding="5,2" Cursor="Hand" FontWeight="Bold" FontSize="10" ToolTip="Eliminar">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid Visibility="{Binding IsDetailVisible}" Background="#E6101010">
            <Button HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20"
                    Command="{Binding BackToListCommand}"
                    Content="🡠 VOLVER" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand"
                    Panel.ZIndex="10"/>

            <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="0,60,0,0">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="600" Margin="0,0,0,50">

                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                        <Border Width="120" Height="120" CornerRadius="10" Background="White" Margin="0,0,0,10">
                            <Image Source="{Binding SelectedSponsor.Url_Logo}" Stretch="Uniform" Margin="10"/>
                        </Border>
                        <TextBlock Text="{Binding SelectedSponsor.Nombre_Empresa}" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Ficha de Patrocinio" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#15FFFFFF" CornerRadius="10" Padding="30" BorderBrush="#20FFFFFF" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Nombre Empresa" Foreground="#FFD700" FontSize="11" FontWeight="Bold"/>
                                <TextBox Text="{Binding SelectedSponsor.Nombre_Empresa, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Sector Industrial" Foreground="White" Opacity="0.7" FontSize="11"/>
                                <TextBox Text="{Binding SelectedSponsor.Sector, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Aporte Económico (€)" Foreground="White" Opacity="0.7" FontSize="11"/>
                                <TextBox Text="{Binding SelectedSponsor.Aporte_Economico, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Logo del Sponsor" Foreground="White" Opacity="0.7" FontSize="11"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{Binding SelectedSponsor.Url_Logo, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

                                    <Button Grid.Column="1" Command="{Binding SelectImageCommand}" Content="..." 
                                            Width="30" Height="25" Margin="5,0,0,0"
                                            Background="#40FFFFFF" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            ToolTip="Examinar Imagen...">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="3"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0">
                                <TextBlock Text="Fecha Inicio (DD/MM/AAAA)" Foreground="White" Opacity="0.7" FontSize="11"/>
                                <DatePicker SelectedDate="{Binding SelectedSponsor.Fecha_Inicio}" Background="Transparent" BorderThickness="0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="2">
                                <TextBlock Text="Fecha Fin (DD/MM/AAAA)" Foreground="White" Opacity="0.7" FontSize="11"/>
                                <DatePicker SelectedDate="{Binding SelectedSponsor.Fecha_Fin}" Background="Transparent" BorderThickness="0"/>
                            </StackPanel>

                            <Button Grid.Row="8" Grid.ColumnSpan="3" Command="{Binding SaveChangesCommand}" 
                                    Content="GUARDAR DATOS" Background="#2E7D32" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>