<UserControl x:Class="InaManager.View.ContratosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:InaManager.ViewModel"
             xmlns:converters="clr-namespace:InaManager.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:ContratosViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisConverter x:Key="BoolToVis" />

        <!-- Estilos para DataGrid -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#40FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#10FFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FFD700"/>
                    <Setter Property="BorderBrush" Value="#FFD700"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EstiloComboBoxGlass" TargetType="ComboBox">
            <Setter Property="Background" Value="#40000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#60FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="5" Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path x:Name="Arrow" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center" 
                                                  Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#60FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,30,3" VerticalAlignment="Center"/>
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                     Margin="10,3,30,3" Focusable="True" Background="Transparent" Foreground="White" BorderThickness="0" 
                                     Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}" CaretBrush="White"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="#EE151515" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="0,0,8,8" 
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="gd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="gd" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="gd" Property="Background" Value="#FFD700"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO Y PESTAÑAS -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="GESTIÓN DE CONTRATOS" FontSize="26" Foreground="White" FontWeight="Bold">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" ShadowDepth="2" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="Administra la masa salarial y cláusulas de tu equipo" FontSize="14" Foreground="#CCCCCC" Margin="0,5,0,15"/>

            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Plantilla de Jugadores" Style="{StaticResource TabButtonStyle}" 
                             Command="{Binding SwitchToJugadoresCommand}" IsChecked="{Binding IsJugadoresTabActive, Mode=OneWay}"/>
                <RadioButton Content="Cuerpo Técnico" Style="{StaticResource TabButtonStyle}" 
                             Command="{Binding SwitchToEmpleadosCommand}" IsChecked="{Binding IsEmpleadosTabActive, Mode=OneWay}"/>
            </StackPanel>
        </StackPanel>

        <!-- ======================= -->
        <!-- PESTAÑA: JUGADORES      -->
        <!-- ======================= -->
        <Grid Grid.Row="1" Grid.RowSpan="2" Visibility="{Binding IsJugadoresTabActive, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- FILTROS JUGADORES -->
            <Border Grid.Row="0" Background="#15000000" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#30FFFFFF" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Buscar Jugador:" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SearchTextJugador, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#20FFFFFF" Foreground="White" BorderBrush="#40FFFFFF" 
                                 Padding="5" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Posición:" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding FiltroPosicion}" SelectedValuePath="Content" Style="{StaticResource EstiloComboBoxGlass}" Height="30">
                            <ComboBoxItem Content="Todas"/>
                            <ComboBoxItem Content="Porteros"/>
                            <ComboBoxItem Content="Defensas"/>
                            <ComboBoxItem Content="Medios"/>
                            <ComboBoxItem Content="Delanteros"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Mercado:" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding FiltroDisponibilidad}" SelectedValuePath="Content" Style="{StaticResource EstiloComboBoxGlass}" Height="30">
                            <ComboBoxItem Content="Todos"/>
                            <ComboBoxItem Content="Transferibles"/>
                            <ComboBoxItem Content="Intransferibles"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DATAGRID JUGADORES -->
            <Border Grid.Row="1" CornerRadius="10" Background="#15000000" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="10">
                <DataGrid ItemsSource="{Binding JugadoresFiltrados}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          HeadersVisibility="Column" 
                          Background="Transparent" 
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="#20FFFFFF"
                          VerticalGridLinesBrush="Transparent"
                          RowHeight="50">
                    <DataGrid.Columns>
                        <!-- FOTO Y NOMBRE -->
                        <DataGridTemplateColumn Header="JUGADOR" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,10,0" BorderBrush="#50FFFFFF" BorderThickness="1">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Url_imagen}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="{Binding Posicion}" Foreground="#FFD700" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- SUELDO -->
                        <DataGridTemplateColumn Header="SUELDO (€/mes)" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Sueldo, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent" 
                                             Padding="5" VerticalAlignment="Center" FontWeight="Bold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- CLAÚSULA -->
                        <DataGridTemplateColumn Header="CLÁUSULA (€)" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Clausula_rescision, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent" 
                                             Padding="5" VerticalAlignment="Center" FontWeight="Bold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- TRANSFERIBLE -->
                        <DataGridTemplateColumn Header="EN MERCADO" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Esta_disponible, UpdateSourceTrigger=PropertyChanged}" 
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- FOOTER JUGADORES -->
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Masa Salarial Jugadores:" Foreground="#AAAAAA" FontSize="16"/>
                    <TextBlock Text="{Binding TotalMasaSalarialJugadores, StringFormat={}{0:N2} €}" Foreground="#FFD700" FontSize="18" FontWeight="Bold" Margin="10,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="GUARDAR CAMBIOS" Command="{Binding GuardarJugadoresCommand}"
                        Background="#FFD700" Foreground="Black" FontWeight="Bold" Padding="20,10" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>

        <!-- ======================= -->
        <!-- PESTAÑA: EMPLEADOS      -->
        <!-- ======================= -->
        <!-- In WPF, instead of InvBoolToVis we can just use Visibility="{Binding IsEmpleadosTabActive, Converter={StaticResource BoolToVis}}" -->
        <!-- I am replacing InvBoolToVis just to be safe if it's not defined in Converters. -->
        <Grid Grid.Row="1" Grid.RowSpan="2" Visibility="{Binding IsEmpleadosTabActive, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- FILTROS EMPLEADOS -->
            <Border Grid.Row="0" Background="#15000000" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#30FFFFFF" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Buscar Empleado:" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SearchTextEmpleado, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#20FFFFFF" Foreground="White" BorderBrush="#40FFFFFF" 
                                 Padding="5" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Puesto:" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding FiltroPuesto}" SelectedValuePath="Content" Style="{StaticResource EstiloComboBoxGlass}" Height="30">
                            <ComboBoxItem Content="Todos"/>
                            <ComboBoxItem Content="Entrenador"/>
                            <ComboBoxItem Content="Director"/>
                            <ComboBoxItem Content="Manager"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DATAGRID EMPLEADOS -->
            <Border Grid.Row="1" CornerRadius="10" Background="#15000000" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="10">
                <DataGrid ItemsSource="{Binding EmpleadosFiltrados}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          HeadersVisibility="Column" 
                          Background="Transparent" 
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="#20FFFFFF"
                          VerticalGridLinesBrush="Transparent"
                          RowHeight="50">
                    <DataGrid.Columns>
                        <!-- FOTO Y NOMBRE -->
                        <DataGridTemplateColumn Header="EMPLEADO" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,10,0" BorderBrush="#50FFFFFF" BorderThickness="1">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Url_imagen}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="{Binding Apellido}" Foreground="#AAAAAA" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="PUESTO" Binding="{Binding Puesto}" Width="1*" Foreground="#FFD700" FontWeight="Bold" IsReadOnly="True"/>
                        <DataGridTextColumn Header="ESPECIALIDAD" Binding="{Binding Especialidad}" Width="1.5*" Foreground="White" IsReadOnly="True"/>

                        <!-- SUELDO -->
                        <DataGridTemplateColumn Header="SUELDO (€/mes)" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Salario, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent" 
                                             Padding="5" VerticalAlignment="Center" FontWeight="Bold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- FOOTER EMPLEADOS -->
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Masa Salarial Empleados:" Foreground="#AAAAAA" FontSize="16"/>
                    <TextBlock Text="{Binding TotalMasaSalarialEmpleados, StringFormat={}{0:N2} €}" Foreground="#FFD700" FontSize="18" FontWeight="Bold" Margin="10,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="GUARDAR CAMBIOS" Command="{Binding GuardarEmpleadosCommand}"
                        Background="#FFD700" Foreground="Black" FontWeight="Bold" Padding="20,10" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>

        <!-- ALERTA / NOTIFICACIÓN -->
        <Grid Visibility="{Binding IsAlertVisible, Converter={StaticResource BoolToVis}}" 
              Grid.Row="0" Grid.RowSpan="3" Margin="-10" Panel.ZIndex="999">

            <Border Background="#AA000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAlertCommand}"/>
                </Border.InputBindings>
            </Border>

            <Border Width="400" MinHeight="180" Background="#1E1E1E" 
                    BorderBrush="{Binding AlertColor}" BorderThickness="2" CornerRadius="12"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.8"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="⚠" FontSize="24" Foreground="{Binding AlertColor}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AlertTitle}" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding AlertMessage}" Foreground="#DDDDDD" FontSize="14" 
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25" LineHeight="20"/>

                    <Button Command="{Binding CloseAlertCommand}"
                            Content="ENTENDIDO" Width="120" Height="35"
                            Background="{Binding AlertColor}" Foreground="White" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="17"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
