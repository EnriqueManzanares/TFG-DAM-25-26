<Window x:Class="InaManager.View.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InaManager.View"
        xmlns:viewModel="clr-namespace:InaManager.ViewModel"
        xmlns:view="clr-namespace:InaManager.View"
        mc:Ignorable="d"
        Title="MainView" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Images/logoInaManager.png"
        MouseDown="Window_MouseDown">

    <Window.DataContext>
        <viewModel:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Color x:Key="winBackColor1">#042e04</Color>
        <Color x:Key="winBackColor2">#684007</Color>
        <Color x:Key="winBackColor3">#6c0b0b</Color>
        <Color x:Key="winBorderColor1">#042e04</Color>
        <Color x:Key="winBorderColor2">#684007</Color>
        <Color x:Key="winBorderColor3">#6c0b0b</Color>

        <DataTemplate DataType="{x:Type viewModel:HomeViewModel}">
            <view:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:EquipoViewModel}">
            <view:EquipoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:PlantillaViewModel}">
            <view:PlantillaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:PartidosViewModel}">
            <view:PartidosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:SupertecnicasViewModel}">
            <view:SupertecnicasView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:SponsorsViewModel}">
            <view:SponsorsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:EmpleadosViewModel}">
            <view:EmpleadosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:FormacionesViewModel}">
            <view:FormacionesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:EjerciciosViewModel}">
            <view:EjerciciosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:ContratosViewModel}">
            <view:ContratosView/>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="20" BorderThickness="5">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource winBorderColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBorderColor2}" Offset="0.5"/>
                <GradientStop Color="{StaticResource winBorderColor3}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Border.Background>
            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                <GradientStop Color="{StaticResource winBackColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBackColor2}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15,0,0,15" Background="#20000000">
                <StackPanel Margin="20" ButtonBase.Click="ReproducirSonidoClick" Cursor="">

                    <Button Command="{Binding ShowPerfilViewCommand}" 
                            MouseEnter="ReproducirSonidoHover"
                            Background="Transparent" BorderThickness="0" 
                            Cursor="Hand" Margin="0,20,0,40"
                            HorizontalAlignment="Left">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="60" Height="60" CornerRadius="30" BorderThickness="2" BorderBrush="White">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding UserAccount.ProfilePicture}" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                            <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserAccount.DisplayName}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="{Binding UserAccount.Rol}" Foreground="#CCC" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <StackPanel>
                        <RadioButton Content="Inicio" Style="{StaticResource MenuButtonStyle}" Command="{Binding ShowHomeViewCommand}" MouseEnter="ReproducirSonidoHover" IsChecked="True"/>
                        <RadioButton Content="Equipo" Style="{StaticResource MenuButtonStyle}" Command="{Binding ShowEquipoViewCommand}" MouseEnter="ReproducirSonidoHover"/>
                        <RadioButton Content="Alineación" Style="{StaticResource MenuButtonStyle}" Command="{Binding ShowPlantillaViewCommand}" MouseEnter="ReproducirSonidoHover"/>
                        
                        <RadioButton Content="Contratos" 
                                     Style="{StaticResource MenuButtonStyle}" 
                                     Command="{Binding ShowContratosViewCommand}"
                                     Visibility="{Binding IsAdminMenuVisible, Converter={StaticResource BoolToVis}}"
                                     MouseEnter="ReproducirSonidoHover"/>

                        <RadioButton Content="Empleados" 
                                     Style="{StaticResource MenuButtonStyle}" 
                                     Command="{Binding ShowEmpleadosViewCommand}"
                                     Visibility="{Binding IsAdminMenuVisible, Converter={StaticResource BoolToVis}}"
                                     MouseEnter="ReproducirSonidoHover"/>

                        <RadioButton Content="Tácticas" 
                                     Style="{StaticResource MenuButtonStyle}" 
                                     Command="{Binding ShowFormacionesViewCommand}"
                                     Visibility="{Binding IsAdminMenuVisible, Converter={StaticResource BoolToVis}}"
                                     MouseEnter="ReproducirSonidoHover"/>

                        <RadioButton Content="Supertécnicas" Style="{StaticResource MenuButtonStyle}" Command="{Binding ShowSupertecnicasViewCommand}" MouseEnter="ReproducirSonidoHover"/>

                        <RadioButton Content="Sponsors" 
                                     Style="{StaticResource MenuButtonStyle}" 
                                     Command="{Binding ShowSponsorsViewCommand}"
                                     Visibility="{Binding IsAdminMenuVisible, Converter={StaticResource BoolToVis}}"
                                     MouseEnter="ReproducirSonidoHover"/>

                        <RadioButton Content="Partidos" Style="{StaticResource MenuButtonStyle}" Command="{Binding ShowPartidosViewCommand}" MouseEnter="ReproducirSonidoHover"/>
                        <RadioButton Content="Ejercicios" Style="{StaticResource MenuButtonStyle}" Command="{Binding ShowEjerciciosViewCommand}" MouseEnter="ReproducirSonidoHover"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,20,0">
                    <Button Content="⬅ Inicio" Foreground="#AAAAAA" Background="Transparent" BorderThickness="0" 
                            Margin="5" Click="btnVolverHub_Click" FontFamily="Montserrat" FontSize="12"
                            Cursor="Hand" ToolTip="Volver al selector de aplicaciones"/>
                    <Button Content="—" Foreground="White" Background="Transparent" BorderThickness="0" Margin="5" Click="btnMinimizar_Click" FontFamily="Montserrat" FontWeight="Bold" Cursor="Hand"/>
                    <Button Content="✕" Foreground="White" Background="Transparent" BorderThickness="0" Margin="5" Click="btnCerrar_Click" FontFamily="Montserrat" Cursor="Hand"/>
                </StackPanel>

                <ContentControl Grid.Row="1" Content="{Binding CurrentChildView}" Margin="20"/>
            </Grid>
        </Grid>
    </Border>
</Window>