<UserControl x:Class="InaManager.View.PartidosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InaManager.View"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:DayColorConverter x:Key="DayColorConverter"/>

        <Style x:Key="EstiloTextBoxLista" TargetType="TextBox">
            <Setter Property="Background" Value="#30000000"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#50FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style x:Key="EstiloComboFinal" TargetType="ComboBox" BasedOn="{StaticResource EstiloComboBoxGlass}">
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FFD700"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EstiloDias" TargetType="CalendarDayButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background">
                <Setter.Value>
                    <MultiBinding Converter="{StaticResource DayColorConverter}">
                        <Binding />
                        <Binding Path="DataContext.TodosLosEventos" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                    </MultiBinding>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="2" BorderThickness="2" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#FFD700"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="#40FFFFFF"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Calendar">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource EstiloDias}"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="AGENDA DE PARTIDOS Y ENTRENOS" FontSize="24" Foreground="White" FontWeight="Bold" FontFamily="Montserrat" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" ShadowDepth="2" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,20,0" CornerRadius="15" Background="#15000000" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Viewbox Stretch="Uniform">
                            <Calendar SelectedDate="{Binding FechaSeleccionada, Mode=TwoWay}"
                                      SelectionMode="SingleDate"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="White"
                                      CalendarDayButtonStyle="{StaticResource EstiloDias}"/>
                        </Viewbox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Ellipse Width="10" Height="10" Fill="#E74C3C" Margin="0,0,5,0"/>
                            <TextBlock Text="Partido" Foreground="White" Opacity="0.8" Margin="0,0,15,0"/>
                            <Ellipse Width="10" Height="10" Fill="#3498DB" Margin="0,0,5,0"/>
                            <TextBlock Text="Entreno" Foreground="White" Opacity="0.8" Margin="0,0,15,0"/>
                        </StackPanel>

                        <Button Grid.Row="2" Command="{Binding AbrirCreadorCommand}"
                                Content="+ AÑADIR EVENTO" Margin="0,20,0,0" Height="40"
                                Background="#FFD700" Foreground="Black" FontWeight="Bold"
                                Cursor="Hand" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Column="1" CornerRadius="15" Background="#15000000" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding TextoFecha}" Foreground="#FFD700" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

                        <TextBlock Grid.Row="1" Text="DÍA LIBRE" Visibility="{Binding EsDiaLibre, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Foreground="#555" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <ListView Grid.Row="1" ItemsSource="{Binding EventosVisibles}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#40000000" CornerRadius="8" Margin="0,0,10,10" BorderBrush="#20FFFFFF" BorderThickness="1">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Color}" CornerRadius="8,0,0,8"/>

                                                <StackPanel Grid.Column="1" Margin="15,10">
                                                    <TextBlock Text="{Binding Tipo}" Foreground="{Binding Color}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Titulo}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Subtitulo}" Foreground="#AAAAAA" FontSize="12"/>
                                                </StackPanel>

                                                <ToggleButton Grid.Column="2" IsChecked="{Binding IsExpanded, Mode=TwoWay}" Content="▼" Width="30" Background="Transparent" Foreground="White" BorderThickness="0"/>

                                                <Button Grid.Column="3" Content="✕" 
                                                        Command="{Binding DataContext.EliminarEventoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding}" Background="Transparent" Foreground="#FF5252" FontWeight="Bold" FontSize="14" BorderThickness="0" Margin="0,0,10,0"/>
                                            </Grid>

                                            <Grid Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#20000000">
                                                <Border BorderBrush="{Binding Color}" BorderThickness="0,1,0,0" Padding="15">
                                                    <StackPanel>
                                                        <ContentControl Content="{Binding}">
                                                            <ContentControl.Style>
                                                                <Style TargetType="ContentControl">
                                                                    <Style.Triggers>

                                                                        <DataTrigger Binding="{Binding Tipo}" Value="Partido">
                                                                            <Setter Property="ContentTemplate">
                                                                                <Setter.Value>
                                                                                    <DataTemplate>
                                                                                        <StackPanel>
                                                                                            <TextBlock Text="MARCADOR:" Foreground="#AAAAAA" FontSize="10" Margin="0,0,0,5"/>
                                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                                                <TextBlock Text="ROYAL" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                                                                <TextBox Text="{Binding GolesLocal, Mode=TwoWay}" Width="35" Margin="10,0" Style="{StaticResource EstiloTextBoxLista}"/>
                                                                                                <TextBlock Text="-" Foreground="Gray" VerticalAlignment="Center"/>
                                                                                                <TextBox Text="{Binding GolesVisitante, Mode=TwoWay}" Width="35" Margin="10,0" Style="{StaticResource EstiloTextBoxLista}"/>
                                                                                                <TextBlock Text="{Binding Titulo}" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                                                            </StackPanel>

                                                                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                                                                <TextBlock Text="Competición: " Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                                                                                <ComboBox Width="160" 
                                                                                                          ItemsSource="{Binding DataContext.ListaCompeticiones, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                                          SelectedItem="{Binding Competicion, Mode=TwoWay}"
                                                                                                          Style="{StaticResource EstiloComboFinal}" 
                                                                                                          Height="28" FontSize="11"/>
                                                                                            </StackPanel>
                                                                                        </StackPanel>
                                                                                    </DataTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>

                                                                        <DataTrigger Binding="{Binding Tipo}" Value="Entrenamiento">
                                                                            <Setter Property="ContentTemplate">
                                                                                <Setter.Value>
                                                                                    <DataTemplate>
                                                                                        <StackPanel>
                                                                                            <TextBlock Text="{Binding NombreEjercicio, StringFormat='• Ejercicio: {0}'}" Foreground="White" Margin="0,0,0,3"/>
                                                                                            <TextBlock Text="{Binding NombreJugador, StringFormat='• Jugador: {0}'}" Foreground="White" Margin="0,0,0,3"/>
                                                                                            <TextBlock Text="{Binding NombreEmpleado, StringFormat='• Supervisor: {0}'}" Foreground="White" Margin="0,0,0,8"/>

                                                                                            <TextBlock Text="Notas / Feedback:" Foreground="#AAAAAA" FontSize="10"/>
                                                                                            <TextBox Text="{Binding Comentarios, Mode=TwoWay}" 
                                                                                                     AcceptsReturn="True" TextWrapping="Wrap" Height="50"
                                                                                                     Background="#20000000" Foreground="White" BorderBrush="#40FFFFFF" 
                                                                                                     Padding="5" Margin="0,2,0,0" CaretBrush="White"/>
                                                                                        </StackPanel>
                                                                                    </DataTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>

                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>

                                                        <Button Content="GUARDAR CAMBIOS" Margin="0,15,0,0" HorizontalAlignment="Right"
                                                                Command="{Binding DataContext.UpdateItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="#2E7D32" Foreground="White" FontWeight="Bold" FontSize="11" 
                                                                Padding="10,5" BorderThickness="0" Cursor="Hand">
                                                            <Button.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="CornerRadius" Value="4"/>
                                                                </Style>
                                                            </Button.Resources>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Visibility="{Binding IsCreatorVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="100" Grid.ColumnSpan="2">

            <Border Background="#B0000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CerrarCreadorCommand}"/>
                </Border.InputBindings>
            </Border>

            <Border Background="#252525" Width="500" 
                    CornerRadius="15" BorderBrush="#FFD700" BorderThickness="2" 
                    Padding="15" VerticalAlignment="Center" HorizontalAlignment="Center">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.7" Color="Black"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="NUEVO EVENTO" Foreground="#FFD700" FontSize="20" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,10" FontFamily="Montserrat"/>

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tipo" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,2"/>
                            <ComboBox ItemsSource="{Binding TiposEvento}" SelectedItem="{Binding FormTipo}" 
                                      Style="{StaticResource EstiloComboFinal}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Fecha" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding FormFecha, StringFormat='dd/MM/yyyy'}" IsReadOnly="True" 
                                     Background="#15FFFFFF" Foreground="White" BorderThickness="0" 
                                     Padding="10,0" Height="35" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <ContentControl Content="{Binding FormTipo}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding FormTipo}" Value="Partido">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="Rival" Foreground="#FF5252" FontWeight="Bold" Margin="0,5,0,2"/>
                                                        <TextBox Text="{Binding DataContext.FormRival, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                 Height="35" Style="{StaticResource EstiloTextBoxLista}" 
                                                                 HorizontalContentAlignment="Left" Padding="5" Margin="0,0,0,8"/>

                                                        <TextBlock Text="Competición" Foreground="#FF5252" FontWeight="Bold" Margin="0,0,0,2"/>
                                                        <ComboBox ItemsSource="{Binding DataContext.ListaCompeticiones, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding DataContext.FormCompeticion, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  Style="{StaticResource EstiloComboFinal}" Margin="0,0,0,10"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding FormTipo}" Value="Entrenamiento">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="Jugador" Foreground="#3498DB" FontWeight="Bold" Margin="0,2,0,2"/>
                                                        <ComboBox ItemsSource="{Binding DataContext.ComboJugadores, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding DataContext.SelectedJugador, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  DisplayMemberPath="Nombre"
                                                                  Style="{StaticResource EstiloComboFinal}" Margin="0,0,0,6"/>

                                                        <TextBlock Text="Ejercicio" Foreground="#3498DB" FontWeight="Bold" Margin="0,0,0,2"/>
                                                        <ComboBox ItemsSource="{Binding DataContext.ComboEjercicios, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding DataContext.SelectedEjercicio, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  DisplayMemberPath="Nombre"
                                                                  Style="{StaticResource EstiloComboFinal}" Margin="0,0,0,6"/>

                                                        <TextBlock Text="Supervisor" Foreground="#3498DB" FontWeight="Bold" Margin="0,0,0,2"/>
                                                        <ComboBox ItemsSource="{Binding DataContext.ComboEmpleados, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding DataContext.SelectedEmpleado, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  DisplayMemberPath="Nombre"
                                                                  Style="{StaticResource EstiloComboFinal}" Margin="0,0,0,6"/>

                                                        <TextBlock Text="Notas" Foreground="Gray" Margin="0,0,0,2"/>
                                                        <TextBox Text="{Binding DataContext.FormComentarios, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                 Height="40" TextWrapping="Wrap" AcceptsReturn="True"
                                                                 Background="#15FFFFFF" Foreground="White" BorderBrush="#40FFFFFF" 
                                                                 Padding="5" Margin="0,0,0,5" CaretBrush="White"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding CerrarCreadorCommand}" 
                                Content="CANCELAR" Height="35"
                                Background="Transparent" Foreground="#AAAAAA" 
                                BorderBrush="#505050" BorderThickness="1" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding GuardarEventoCommand}" 
                                Content="GUARDAR" Height="35"
                                Background="#FFD700" Foreground="Black" FontWeight="Bold" 
                                BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Visibility="{Binding IsAlertVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999" Grid.ColumnSpan="2">
            <Border Background="#90000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAlertCommand}"/>
                </Border.InputBindings>
            </Border>

            <Border Width="400" MinHeight="180" Background="#252525" 
                    BorderBrush="{Binding AlertColor}" BorderThickness="3" CornerRadius="15"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.8" Color="Black"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Ellipse Width="15" Height="15" Fill="{Binding AlertColor}" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding AlertTitle}" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding AlertMessage}" Foreground="#DDDDDD" FontSize="15" 
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30" LineHeight="22"/>

                    <Button Command="{Binding CloseAlertCommand}"
                            Content="ACEPTAR" Width="140" Height="40"
                            Background="{Binding AlertColor}" Foreground="White" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>