<Window x:Class="InaManager.View.AppHubView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:InaManager.ViewModel"
        mc:Ignorable="d" 
        Title="InaManager Hub" Height="600" Width="1000"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.DataContext>
        <vm:AppHubViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Fondo con el mismo gradiente que el Login -->
    <Border CornerRadius="20" BorderThickness="3">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#042e04" Offset="0"/>
                <GradientStop Color="#684007" Offset="0.5"/>
                <GradientStop Color="#6c0b0b" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1B0D" Offset="0"/>
                <GradientStop Color="#1A0E05" Offset="0.5"/>
                <GradientStop Color="#1A0505" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- BARRA SUPERIOR: título + botones de ventana -->
            <Grid Grid.Row="0" Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#FFD700" Margin="0,0,8,0"/>
                    <TextBlock Text="INA ECOSYSTEM" Foreground="#AAAAAA" FontSize="12" 
                               FontFamily="Montserrat" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="—" Foreground="White" Background="Transparent" BorderThickness="0" 
                            Margin="5,0" Click="btnMinimizar_Click" FontFamily="Montserrat" FontWeight="Bold" Cursor="Hand"/>
                    <Button Content="✕" Foreground="White" Background="Transparent" BorderThickness="0" 
                            Margin="5,0" Click="btnCerrar_Click" FontFamily="Montserrat" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- CONTENIDO CENTRAL: usuario + 3 apps -->
            <Grid Grid.Row="1" Margin="50,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Saludo al usuario -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,30">
                    <TextBlock FontSize="14" Foreground="#AAAAAA" FontFamily="Montserrat"
                               HorizontalAlignment="Center">
                        <Run Text="Bienvenido/a, "/>
                        <Run Text="{Binding NombreUsuario, Mode=OneWay}" FontWeight="Bold" Foreground="White"/>
                    </TextBlock>
                    <TextBlock Text="Selecciona una aplicación para continuar" 
                               FontSize="26" FontWeight="Bold" Foreground="White" 
                               FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="3" BlurRadius="10" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- LAS 3 APPS -->
                <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">

                    <!-- APP IZQUIERDA: BANCO -->
                    <Button Command="{Binding AbrirBancoCommand}" Margin="10" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CardBorder" CornerRadius="18" 
                                        BorderThickness="1.5" BorderBrush="#30FFFFFF"
                                        Background="#15FFFFFF">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                        <!-- Icono Banco -->
                                        <Border Width="90" Height="90" CornerRadius="45" Margin="0,0,0,20"
                                                Background="#1A3A5C">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#1E6EBF" ShadowDepth="0" BlurRadius="20" Opacity="0.8"/>
                                            </Border.Effect>
                                            <TextBlock Text="🏦" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="BANCO" FontSize="22" FontWeight="Bold" Foreground="White" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Gestiona tus finanzas" FontSize="12" Foreground="#AAAAAA" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        <!-- Badge "Próximamente" -->
                                        <Border Background="#1E6EBF" CornerRadius="8" Padding="8,3" Margin="0,12,0,0" HorizontalAlignment="Center">
                                            <TextBlock Text="PRÓXIMAMENTE" FontSize="10" FontWeight="Bold" 
                                                       Foreground="White" FontFamily="Montserrat"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="#25FFFFFF"/>
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#601E6EBF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="#35FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- APP CENTRAL: INA MANAGER (destacada) -->
                    <Button Command="{Binding AbrirInaManagerCommand}" Margin="10" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CardBorderMain" CornerRadius="18"
                                        BorderThickness="2" BorderBrush="#80FFD700"
                                        Background="#20FFD700">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FFD700" ShadowDepth="0" BlurRadius="25" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                        <!-- Logo InaManager -->
                                        <Border Width="100" Height="100" CornerRadius="50" Margin="0,0,0,20"
                                                Background="#1A1A00">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#FFD700" ShadowDepth="0" BlurRadius="25" Opacity="0.9"/>
                                            </Border.Effect>
                                            <Image Source="/Images/Logo.png" Width="70" Height="70" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="INA MANAGER" FontSize="22" FontWeight="Bold" Foreground="#FFD700" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Gestión del equipo" FontSize="12" Foreground="#CCCCCC" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        <!-- Badge "Disponible" -->
                                        <Border Background="#2E7D32" CornerRadius="8" Padding="8,3" Margin="0,12,0,0" HorizontalAlignment="Center">
                                            <TextBlock Text="▶  ENTRAR" FontSize="10" FontWeight="Bold" 
                                                       Foreground="White" FontFamily="Montserrat"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorderMain" Property="Background" Value="#35FFD700"/>
                                        <Setter TargetName="CardBorderMain" Property="BorderBrush" Value="#BFFFD700"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CardBorderMain" Property="Background" Value="#45FFD700"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- APP DERECHA: MERCADO -->
                    <Button Command="{Binding AbrirMercadoCommand}" Margin="10" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CardBorderM" CornerRadius="18"
                                        BorderThickness="1.5" BorderBrush="#30FFFFFF"
                                        Background="#15FFFFFF">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                        <!-- Icono Mercado -->
                                        <Border Width="90" Height="90" CornerRadius="45" Margin="0,0,0,20"
                                                Background="#3A1A5C">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#9B59B6" ShadowDepth="0" BlurRadius="20" Opacity="0.8"/>
                                            </Border.Effect>
                                            <TextBlock Text="⚽" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="MERCADO DE FICHAJES" FontSize="18" FontWeight="Bold" Foreground="White" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Text="Busca y ficha jugadores" FontSize="12" Foreground="#AAAAAA" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        <!-- Badge "Próximamente" -->
                                        <Border Background="#6C3483" CornerRadius="8" Padding="8,3" Margin="0,12,0,0" HorizontalAlignment="Center">
                                            <TextBlock Text="PRÓXIMAMENTE" FontSize="10" FontWeight="Bold" 
                                                       Foreground="White" FontFamily="Montserrat"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorderM" Property="Background" Value="#25FFFFFF"/>
                                        <Setter TargetName="CardBorderM" Property="BorderBrush" Value="#609B59B6"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CardBorderM" Property="Background" Value="#35FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </UniformGrid>
            </Grid>

            <!-- FOOTER: botón volver -->
            <Grid Grid.Row="2" Margin="30,0">
                <Button Command="{Binding VolverAlLoginCommand}" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <StackPanel Orientation="Horizontal" x:Name="BtnVolver">
                                <TextBlock Text="←" FontSize="16" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Cerrar sesión" FontSize="14" Foreground="#AAAAAA" 
                                           FontFamily="Montserrat" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnVolver" Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="0" Opacity="0"/>
                    </Button.Effect>
                </Button>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#333333" FontSize="11" FontFamily="Montserrat">
                    <Run Text="INA Ecosystem  ·  v1.0"/>
                </TextBlock>
            </Grid>

            <!-- OVERLAY ALERTA "EN DESARROLLO" -->
            <Grid Grid.Row="0" Grid.RowSpan="3"
                  Visibility="{Binding IsAlertVisible, Converter={StaticResource BoolToVis}}"
                  Panel.ZIndex="999">
                <Border Background="#AA000000">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAlertCommand}"/>
                    </Border.InputBindings>
                </Border>
                <Border Width="420" Background="#1E1E1E" CornerRadius="14"
                        BorderBrush="{Binding AlertColor}" BorderThickness="2"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="🚧" FontSize="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AlertTitle}" FontSize="22" FontWeight="Bold" 
                                       Foreground="White" FontFamily="Montserrat" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AlertMessage}" Foreground="#DDDDDD" FontSize="14"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25" LineHeight="22"
                                   FontFamily="Montserrat"/>
                        <Button Command="{Binding CloseAlertCommand}" Content="ENTENDIDO"
                                Width="130" Height="38" Background="{Binding AlertColor}"
                                Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Center" FontFamily="Montserrat">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="19"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
