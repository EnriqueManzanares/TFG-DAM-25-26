<Window x:Class="InaManager.View.AppHubView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:InaManager.ViewModel"
        mc:Ignorable="d" 
        Title="InaManager Hub" Height="600" Width="1000"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.DataContext>
        <vm:AppHubViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- POPUP MENÚ DE CERRAR SESIÓN -->
        <Popup x:Key="WindowsMenuPopup" x:Shared="False" StaysOpen="False" AllowsTransparency="True" Placement="Top" PopupAnimation="Fade">
            <Border Background="#1F1F1F" BorderBrush="#404040" BorderThickness="1" CornerRadius="4" Padding="0" Margin="0,0,0,-50">
                <Button Click="MenuItem_CerrarSesion" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="MenuItemBorder" Background="Transparent" Padding="15,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚪" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cerrar sesión" FontFamily="Montserrat" VerticalAlignment="Center" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MenuItemBorder" Property="Background" Value="#2F2F2F"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Popup>
    </Window.Resources>

    <!-- Fondo con imagen -->
    <Border CornerRadius="20" BorderThickness="3">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#042e04" Offset="0"/>
                <GradientStop Color="#684007" Offset="0.5"/>
                <GradientStop Color="#6c0b0b" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <ImageBrush ImageSource="/Images/Fondoescritorio.jpg" Stretch="UniformToFill"/>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- BARRA SUPERIOR: título + botones de ventana -->
            <Grid Grid.Row="0" Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#FFD700" Margin="0,0,8,0"/>
                    <TextBlock Text="INA ECOSYSTEM" Foreground="#AAAAAA" FontSize="12" 
                               FontFamily="Montserrat" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Margin="5,0" Click="btnMinimizar_Click" Cursor="Hand" BorderThickness="0" Width="30" Height="30">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="White" CornerRadius="4" BorderThickness="0">
                                    <TextBlock Text="—" Foreground="Black" FontSize="16" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#E0E0E0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#CCCCCC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Margin="5,0" Click="btnCerrar_Click" Cursor="Hand" BorderThickness="0" Width="30" Height="30">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="White" CornerRadius="4" BorderThickness="0">
                                    <TextBlock Text="✕" Foreground="Black" FontSize="14" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#E0E0E0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#CCCCCC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- CONTENIDO CENTRAL: usuario + botones laterales + contenido principal -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- PANEL LATERAL IZQUIERDO: 3 botones verticales -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="20,20,10,20" VerticalAlignment="Top" Width="110">

                    <!-- BOTÓN BANCO -->
                    <Button Command="{Binding AbrirBancoCommand}" Margin="0,0,0,10" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Height="95">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CardBorder" CornerRadius="12" 
                                        BorderThickness="1.5" BorderBrush="#30FFFFFF"
                                        Background="#15FFFFFF">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Text="🏦" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="BANCO" FontSize="13" FontWeight="Bold" Foreground="White" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Text="Finanzas" FontSize="9" Foreground="#AAAAAA" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="#25FFFFFF"/>
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#601E6EBF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="#35FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- BOTÓN INA MANAGER -->
                    <Button Command="{Binding AbrirInaManagerCommand}" Margin="0,0,0,10" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Height="95">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CardBorderMain" CornerRadius="12"
                                        BorderThickness="2" BorderBrush="#30FFD700"
                                        Background="Transparent">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FFD700" ShadowDepth="0" BlurRadius="15" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                                        <Image Source="/Images/Logo.png" Width="40" Height="40" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="INAMANAGER" FontSize="13" FontWeight="Bold" Foreground="#FFD700" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" TextAlignment="Center"/>
                                        <TextBlock Text="Equipo" FontSize="9" Foreground="#CCCCCC" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorderMain" Property="Background" Value="#20FFD700"/>
                                        <Setter TargetName="CardBorderMain" Property="BorderBrush" Value="#BFFFD700"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CardBorderMain" Property="Background" Value="#45FFD700"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- BOTÓN MERCADO -->
                    <Button Command="{Binding AbrirMercadoCommand}" Margin="0,0,0,0" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Height="95">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CardBorderM" CornerRadius="12"
                                        BorderThickness="1.5" BorderBrush="#30FFFFFF"
                                        Background="#15FFFFFF">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Text="⚽" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="MERCADO" FontSize="13" FontWeight="Bold" Foreground="White" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Text="Fichajes" FontSize="9" Foreground="#AAAAAA" 
                                                   FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorderM" Property="Background" Value="#25FFFFFF"/>
                                        <Setter TargetName="CardBorderM" Property="BorderBrush" Value="#609B59B6"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CardBorderM" Property="Background" Value="#35FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

                <!-- ÁREA CENTRAL/DERECHA: Saludo y contenido -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                </StackPanel>

            </Grid>

            <!-- FOOTER: BARRA DE TAREAS ESTILO WINDOWS -->
            <Border Grid.Row="2" Background="#0D47A1" BorderThickness="1,0,0,0" BorderBrush="#0D47A1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">

                    <!-- BOTÓN WINDOWS (LOGO) CON MENÚ DESPLEGABLE -->
                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="WindowsButton_Click" Width="50" Height="50" VerticalAlignment="Stretch" x:Name="WindowsButton">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="WindowsButtonBorder" Background="Transparent" BorderThickness="0">
                                    <TextBlock Text="⊞" FontSize="20" Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="WindowsButtonBorder" Property="Background" Value="#262626"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="WindowsButtonBorder" Property="Background" Value="#404040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- SEPARADOR -->
                    <Border Width="1" Background="#262626" Margin="0,5"/>

                    <!-- INFORMACIÓN ADICIONAL -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="INA Ecosystem" Foreground="#808080" FontSize="11" 
                                   FontFamily="Montserrat" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- SPACER -->
                    <Grid HorizontalAlignment="Stretch"/>

                    <!-- RELOJ/INFO DERECHA -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="v1.0" Foreground="#808080" FontSize="11" 
                                   FontFamily="Montserrat" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- OVERLAY ALERTA "EN DESARROLLO" -->
            <Grid Grid.Row="0" Grid.RowSpan="3"
                  Visibility="{Binding IsAlertVisible, Converter={StaticResource BoolToVis}}"
                  Panel.ZIndex="999">
                <Border Background="#AA000000">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAlertCommand}"/>
                    </Border.InputBindings>
                </Border>
                <Border Width="420" Background="#1E1E1E" CornerRadius="14"
                        BorderBrush="{Binding AlertColor}" BorderThickness="2"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="🚧" FontSize="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AlertTitle}" FontSize="22" FontWeight="Bold" 
                                       Foreground="White" FontFamily="Montserrat" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AlertMessage}" Foreground="#DDDDDD" FontSize="14"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25" LineHeight="22"
                                   FontFamily="Montserrat"/>
                        <Button Command="{Binding CloseAlertCommand}" Content="ENTENDIDO"
                                Width="130" Height="38" Background="{Binding AlertColor}"
                                Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Center" FontFamily="Montserrat">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="19"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
