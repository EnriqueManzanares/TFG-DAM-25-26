<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--Colores de fondo-->
    <Color x:Key = "winBackColor1">#042e04</Color>
    <Color x:Key = "winBackColor2">#684007</Color>
    <Color x:Key = "winBackColor3">#6c0b0b</Color>

    <!--Colores del borde-->
    <Color x:Key = "winBorderColor1">#042e04</Color>
    <Color x:Key = "winBorderColor2">#684007</Color>
    <Color x:Key = "winBorderColor3">#6c0b0b</Color>



    <!--Paleta de colores-->

    <SolidColorBrush x:Key="color1" Color="#9e3f3f"/>
    <SolidColorBrush x:Key="color2" Color="Pink"/>
    <SolidColorBrush x:Key="color3" Color="DarkGray"/>

    

</ResourceDictionary>